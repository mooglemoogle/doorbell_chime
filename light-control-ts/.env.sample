# Set to DEVELOPMENT to enable mock mode (no hardware required)
# piixel will use MOCK_PIIXEL automatically when this is set via `bun run dev`
MODE=DEVELOPMENT

# Optionally set MOCK_PIIXEL directly to control piixel's mock behavior:
#   MOCK_PIIXEL=1        display in terminal (single row)
#   MOCK_PIIXEL=2x8      display as 2-row grid
#   MOCK_PIIXEL=-1       mock without terminal output
# MOCK_PIIXEL=1
